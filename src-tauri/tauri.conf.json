{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vault-chat",
  "version": "0.1.0",
  "identifier": "com.vault-chat.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "vault-chat",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "theme": "Dark",
        "decorations": false,
        "backgroundColor": "#1f1f23",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
