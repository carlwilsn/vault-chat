#!/usr/bin/env bash
# vault-chat launcher — macOS + Linux.
# Checks toolchain, installs node deps on first run, then launches
# the Tauri dev server. Add this folder to PATH so `vc` just works.
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO="$(cd "$SCRIPT_DIR/.." && pwd)"

need() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "vault-chat: missing '$1'." >&2
    echo "$2" >&2
    exit 1
  fi
}

need node "Install Node 20+ — https://nodejs.org"
need cargo "Install Rust via rustup — https://rustup.rs"
need git "Install git — https://git-scm.com/downloads"

cd "$REPO"

if [ ! -d node_modules ] || [ package-lock.json -nt node_modules ]; then
  echo "vault-chat: installing node deps (one-time, ~1 min)…"
  npm install --silent
fi

exec npm run tauri dev
